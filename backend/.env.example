PORT=5000
# JSON for a Firebase service account with Firestore, Auth and Storage access.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# Optional OCR.Space key. Without it, the review table opens but OCR returns no suggested rows.
OCR_SPACE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
