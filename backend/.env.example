PORT=5000
# JSON for a Firebase service account with Firestore, Auth and Storage access.
# FIREBASE_SERVICE_ACCOUNT_JSON is also accepted for existing deployments.
FIREBASE_SERVICE_ACCOUNT=your_service_account_json_optional
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
OCR_SPACE_API_KEY=your_key_here
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
